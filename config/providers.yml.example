# LLM Gateway Configuration
# Place your API keys here (not for production with sensitive keys)

providers:
  ollama:
    base_url: "https://ollama.com/v1"
    strategy: "sequential"
    timeout: 120
    max_retries: 3
    keys:
      - key: "YOUR_OLLAMA_API_KEY_HERE"
        models: ["logic-supreme", "code-architect", "author-pro", "omni-think"]
      - key: "YOUR_OLLAMA_API_KEY_HERE"
        models: ["logic-supreme", "code-architect", "author-pro", "omni-think"]
      - key: "YOUR_OLLAMA_API_KEY_HERE"
        models: ["logic-supreme", "code-architect", "author-pro", "omni-think"]
      - key: "YOUR_OLLAMA_API_KEY_HERE"
        models: ["logic-supreme", "code-architect", "author-pro", "omni-think"]
      - key: "YOUR_OLLAMA_API_KEY_HERE"
        models: ["logic-supreme", "code-architect", "author-pro", "omni-think"]
      - key: "YOUR_OLLAMA_API_KEY_HERE"
        models: ["logic-supreme", "code-architect", "author-pro", "omni-think"]
      - key: "YOUR_OLLAMA_API_KEY_HERE"
        models: ["logic-supreme", "code-architect", "author-pro", "omni-think"]
    # Model mappings (alias -> actual model name)
    models:
      logic-supreme: "kimi-k2.5:cloud"
      code-architect: "qwen3-coder:480b-cloud"
      author-pro: "glm-5:cloud"
      omni-think: "deepseek-v3.2:cloud"

# Model aliases - maps generic names to providers
models:
  # 'logic-supreme' focuses on deep reasoning
  "logic-supreme":
    providers: ["ollama"]
  
  # 'code-architect' for expert coding
  "code-architect":
    providers: ["ollama"]
  
  # 'author-pro' for high-quality writing
  "author-pro":
    providers: ["ollama"]

  # 'omni-think' for general purpose performance
  "omni-think":
    providers: ["ollama"]
  
  # OpenAI-compatible model names for backward compatibility or direct access
  "gpt-4":
    providers: ["ollama"]
  
  "gpt-3.5-turbo":
    providers: ["ollama"]

  "deepseek-v3.2":
    providers: ["ollama"]

# Gateway settings
gateway:
  host: "0.0.0.0"
  port: 8000
  log_level: "INFO"
  max_workers: 10

# Circuit breaker settings
circuit_breaker:
  failure_threshold: 3
  recovery_timeout: 30.0  # seconds
